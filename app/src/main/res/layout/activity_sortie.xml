<?xml version="1.0" encoding="utf-8"?>
<!--
    Sortie Screen
    Includes a large amount display (red) and a dark Valider button.
-->
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/main_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF">

    <!-- Header -->
    <RelativeLayout
        android:id="@+id/header"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="16dp">

        <ImageView
            android:id="@+id/btnBack"
            android:layout_width="30dp"
            android:layout_height="30dp"
            android:layout_centerVertical="true"
            android:src="@android:drawable/ic_menu_revert"
            app:tint="#3498DB"
            android:contentDescription="@null" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerInParent="true"
            android:text="@string/btn_sortie"
            android:textColor="#3498DB"
            android:textSize="18sp"
            android:textStyle="bold" />
    </RelativeLayout>

    <!-- Amount Display Area -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@id/header"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/label_sortie"
            android:textColor="#BDC3C7"
            android:textSize="12sp" />

        <TextView
            android:id="@+id/tvAmount"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/default_amount"
            android:textColor="#E74C3C"
            android:textSize="32sp"
            android:textStyle="bold" />
    </LinearLayout>

    <!-- Calculator and Validate Section -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:orientation="vertical">

        <!-- VALIDER Button (Dark style for Sortie) -->
        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btnValider"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"
            android:layout_marginBottom="8dp"
            android:background="@drawable/bg_dark_purple_btn"
            android:text="@string/btn_validate"
            android:textColor="#E74C3C"
            android:textStyle="bold" />

        <!-- Keypad -->
        <GridLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:columnCount="4"
            android:padding="4dp"
            android:background="#F8F9FA">

            <Button style="?android:attr/borderlessButtonStyle" android:layout_width="0dp" android:layout_height="65dp" android:layout_columnWeight="1" android:layout_margin="2dp" android:background="@drawable/bg_light_blue_btn" android:text="AC" android:textColor="#3498DB" android:textSize="18sp" />
            <Button style="?android:attr/borderlessButtonStyle" android:layout_width="0dp" android:layout_height="65dp" android:layout_columnWeight="1" android:layout_margin="2dp" android:background="@drawable/bg_light_blue_btn" android:text="M+" android:textColor="#3498DB" android:textSize="18sp" />
            <Button style="?android:attr/borderlessButtonStyle" android:layout_width="0dp" android:layout_height="65dp" android:layout_columnWeight="1" android:layout_margin="2dp" android:background="@drawable/bg_light_blue_btn" android:text="M-" android:textColor="#3498DB" android:textSize="18sp" />
            <ImageView android:layout_width="0dp" android:layout_height="65dp" android:layout_columnWeight="1" android:layout_margin="2dp" android:background="@drawable/bg_light_blue_btn" android:padding="20dp" android:src="@android:drawable/ic_menu_close_clear_cancel" app:tint="#3498DB" android:scaleType="centerInside" android:contentDescription="@null" />

            <Button style="?android:attr/borderlessButtonStyle" android:layout_width="0dp" android:layout_height="65dp" android:layout_columnWeight="1" android:layout_margin="2dp" android:text="7" android:textColor="#333333" android:textSize="20sp" />
            <Button style="?android:attr/borderlessButtonStyle" android:layout_width="0dp" android:layout_height="65dp" android:layout_columnWeight="1" android:layout_margin="2dp" android:text="8" android:textColor="#333333" android:textSize="20sp" />
            <Button style="?android:attr/borderlessButtonStyle" android:layout_width="0dp" android:layout_height="65dp" android:layout_columnWeight="1" android:layout_margin="2dp" android:text="9" android:textColor="#333333" android:textSize="20sp" />
            <Button style="?android:attr/borderlessButtonStyle" android:layout_width="0dp" android:layout_height="65dp" android:layout_columnWeight="1" android:layout_margin="2dp" android:background="@drawable/bg_light_blue_btn" android:text="/" android:textColor="#3498DB" android:textSize="24sp" />

            <Button style="?android:attr/borderlessButtonStyle" android:layout_width="0dp" android:layout_height="65dp" android:layout_columnWeight="1" android:layout_margin="2dp" android:text="4" android:textColor="#333333" android:textSize="20sp" />
            <Button style="?android:attr/borderlessButtonStyle" android:layout_width="0dp" android:layout_height="65dp" android:layout_columnWeight="1" android:layout_margin="2dp" android:text="5" android:textColor="#333333" android:textSize="20sp" />
            <Button style="?android:attr/borderlessButtonStyle" android:layout_width="0dp" android:layout_height="65dp" android:layout_columnWeight="1" android:layout_margin="2dp" android:text="6" android:textColor="#333333" android:textSize="20sp" />
            <Button style="?android:attr/borderlessButtonStyle" android:layout_width="0dp" android:layout_height="65dp" android:layout_columnWeight="1" android:layout_margin="2dp" android:background="@drawable/bg_light_blue_btn" android:text="×" android:textColor="#3498DB" android:textSize="24sp" />

            <Button style="?android:attr/borderlessButtonStyle" android:layout_width="0dp" android:layout_height="65dp" android:layout_columnWeight="1" android:layout_margin="2dp" android:text="1" android:textColor="#333333" android:textSize="20sp" />
            <Button style="?android:attr/borderlessButtonStyle" android:layout_width="0dp" android:layout_height="65dp" android:layout_columnWeight="1" android:layout_margin="2dp" android:text="2" android:textColor="#333333" android:textSize="20sp" />
            <Button style="?android:attr/borderlessButtonStyle" android:layout_width="0dp" android:layout_height="65dp" android:layout_columnWeight="1" android:layout_margin="2dp" android:text="3" android:textColor="#333333" android:textSize="20sp" />
            <Button style="?android:attr/borderlessButtonStyle" android:layout_width="0dp" android:layout_height="65dp" android:layout_columnWeight="1" android:layout_margin="2dp" android:background="@drawable/bg_light_blue_btn" android:text="-" android:textColor="#3498DB" android:textSize="24sp" />

            <Button style="?android:attr/borderlessButtonStyle" android:layout_width="0dp" android:layout_height="65dp" android:layout_columnWeight="1" android:layout_margin="2dp" android:text="0" android:textColor="#333333" android:textSize="20sp" />
            <Button style="?android:attr/borderlessButtonStyle" android:layout_width="0dp" android:layout_height="65dp" android:layout_columnWeight="1" android:layout_margin="2dp" android:text="." android:textColor="#333333" android:textSize="24sp" />
            <Button style="?android:attr/borderlessButtonStyle" android:layout_width="0dp" android:layout_height="65dp" android:layout_columnWeight="1" android:layout_margin="2dp" android:background="@drawable/bg_light_blue_btn" android:text="=" android:textColor="#3498DB" android:textSize="24sp" />
            <Button style="?android:attr/borderlessButtonStyle" android:layout_width="0dp" android:layout_height="65dp" android:layout_columnWeight="1" android:layout_margin="2dp" android:background="@drawable/bg_light_blue_btn" android:text="+" android:textColor="#3498DB" android:textSize="24sp" />

        </GridLayout>
    </LinearLayout>

</RelativeLayout>