<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/main_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F8F9FA">

    <!-- Header -->
    <RelativeLayout
        android:id="@+id/header"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#FFFFFF"
        android:padding="16dp">

        <ImageView
            android:id="@+id/btnBack"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_centerVertical="true"
            android:src="@android:drawable/ic_menu_revert"
            app:tint="#3498DB" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerInParent="true"
            android:text="@string/title_rapport"
            android:textColor="#3498DB"
            android:textSize="18sp"
            android:textStyle="bold" />
    </RelativeLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@id/header">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Period Selector -->
            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btnSelectPeriod"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:background="@drawable/button_shape_global"
                android:backgroundTint="#FFFFFF"
                android:drawableStart="@android:drawable/ic_menu_today"
                android:drawableEnd="@android:drawable/arrow_down_float"
                android:drawablePadding="12dp"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:text="Avril"
                android:textAllCaps="false"
                android:textColor="#3498DB"
                android:gravity="center_vertical|start" />

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginTop="8dp"
                android:background="#EEEEEE" />

            <!-- Tabs -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:background="@drawable/button_shape_global"
                android:backgroundTint="#F8F9FA"
                android:padding="4dp"
                android:elevation="0dp"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/tabApercu"
                    android:layout_width="0dp"
                    android:layout_height="40dp"
                    android:layout_weight="1"
                    android:background="@drawable/button_shape_global"
                    android:backgroundTint="#FFFFFF"
                    android:gravity="center"
                    android:text="@string/tab_apercu"
                    android:textColor="#3498DB"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tabDetails"
                    android:layout_width="0dp"
                    android:layout_height="40dp"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:text="@string/tab_details"
                    android:textColor="#7F8C8D" />
            </LinearLayout>

            <!-- Aperçu Content -->
            <LinearLayout
                android:id="@+id/layoutOverview"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="visible">

                <!-- Summary Card matched to screenshot -->
                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="2dp">

                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:padding="20dp">

                        <TextView
                            android:id="@+id/labelSolde"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/label_solde_text"
                            android:textColor="#3498DB"
                            android:textSize="16sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/tvSummarySolde"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_below="@id/labelSolde"
                            android:layout_marginTop="8dp"
                            android:text="@string/default_amount"
                            android:textColor="#27AE60"
                            android:textSize="28sp"
                            android:textStyle="bold" />

                        <androidx.appcompat.widget.AppCompatButton
                            android:id="@+id/btnExport"
                            android:layout_width="wrap_content"
                            android:layout_height="40dp"
                            android:layout_alignParentEnd="true"
                            android:layout_centerVertical="true"
                            android:background="@drawable/bg_light_blue_btn"
                            android:drawableEnd="@android:drawable/stat_sys_download"
                            android:drawablePadding="8dp"
                            android:paddingStart="12dp"
                            android:paddingEnd="12dp"
                            android:text="@string/btn_telecharger"
                            android:textAllCaps="false"
                            android:textColor="#3498DB"
                            android:textSize="12sp" />

                        <View
                            android:id="@+id/divider"
                            android:layout_width="match_parent"
                            android:layout_height="1dp"
                            android:layout_below="@id/tvSummarySolde"
                            android:layout_marginTop="20dp"
                            android:background="#F0F0F0" />

                        <!-- Encaissement -->
                        <RelativeLayout
                            android:id="@+id/layoutEncaissement"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_below="@id/divider"
                            android:layout_marginTop="16dp">

                            <TextView
                                android:id="@+id/labelEncaissement"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/label_encaissement_total"
                                android:textColor="#3498DB"
                                android:textStyle="bold" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_below="@id/labelEncaissement"
                                android:text="1 Opération"
                                android:textColor="#7F8C8D"
                                android:textSize="12sp" />

                            <TextView
                                android:id="@+id/tvSummaryEntree"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_alignParentEnd="true"
                                android:layout_centerVertical="true"
                                android:text="@string/default_amount"
                                android:textColor="#27AE60"
                                android:textStyle="bold" />
                        </RelativeLayout>

                        <View
                            android:id="@+id/divider2"
                            android:layout_width="match_parent"
                            android:layout_height="1dp"
                            android:layout_below="@id/layoutEncaissement"
                            android:layout_marginTop="16dp"
                            android:background="#F0F0F0" />

                        <!-- Décaissement -->
                        <RelativeLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_below="@id/divider2"
                            android:layout_marginTop="16dp">

                            <TextView
                                android:id="@+id/labelDecaissement"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/label_decaissement_total"
                                android:textColor="#3498DB"
                                android:textStyle="bold" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_below="@id/labelDecaissement"
                                android:text="0 Opération"
                                android:textColor="#7F8C8D"
                                android:textSize="12sp" />

                            <TextView
                                android:id="@+id/tvSummarySortie"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_alignParentEnd="true"
                                android:layout_centerVertical="true"
                                android:text="@string/default_amount"
                                android:textColor="#E74C3C"
                                android:textStyle="bold" />
                        </RelativeLayout>

                    </RelativeLayout>
                </androidx.cardview.widget.CardView>
            </LinearLayout>

            <!-- Détails Content -->
            <LinearLayout
                android:id="@+id/layoutDetails"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:orientation="vertical"
                android:visibility="gone">

                <!-- Sample Detail Item -->
                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="8dp"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="1dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:padding="12dp">

                        <ImageView
                            android:layout_width="36dp"
                            android:layout_height="36dp"
                            android:background="@drawable/button_shape_global"
                            android:backgroundTint="#E8F5E9"
                            android:padding="8dp"
                            android:src="@android:drawable/ic_input_add"
                            app:tint="#27AE60" />

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="12dp"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/label_entree"
                                android:textColor="#333333"
                                android:textStyle="bold" />

                            <TextView
                                android:id="@+id/tvDetailSolde"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/default_amount"
                                android:textColor="#7F8C8D"
                                android:textSize="12sp" />
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:gravity="end"
                            android:orientation="vertical">

                            <TextView
                                android:id="@+id/tvDetailAmount"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/default_amount"
                                android:textColor="#27AE60"
                                android:textStyle="bold" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Aujourd'hui à 20:34"
                                android:textColor="#BDC3C7"
                                android:textSize="10sp" />
                        </LinearLayout>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

            </LinearLayout>

        </LinearLayout>
    </ScrollView>
</RelativeLayout>