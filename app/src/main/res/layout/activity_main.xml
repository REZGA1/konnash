<?xml version="1.0" encoding="utf-8"?>
<!--
    Language Selection Screen
    This layout stacks the logo and buttons vertically.
-->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF"
    android:gravity="center_horizontal"
    android:orientation="vertical"
    android:paddingLeft="70dp"
    android:paddingRight="70dp"
    android:paddingTop="80dp">

    <!-- App Logo: sized and spaced to match the provided design -->
    <ImageView
        android:id="@+id/logo"
        android:layout_width="140dp"
        android:layout_height="140dp"
        android:layout_marginBottom="80dp"
        android:contentDescription="@string/app_logo_description"
        android:src="@drawable/ic_language_logo" />

    <!--
        Language Buttons:
        - Width matches the available space inside the 70dp padding.
        - Style 'LanguageButtonStyle' handles height, corners, and text color.
    -->
    <androidx.appcompat.widget.AppCompatButton
        android:id="@+id/btnTurkish"
        style="@style/LanguageButtonStyle"
        android:text="@string/lang_turkish" />

    <androidx.appcompat.widget.AppCompatButton
        android:id="@+id/btnEnglish"
        style="@style/LanguageButtonStyle"
        android:layout_marginTop="20dp"
        android:text="@string/lang_english" />

    <androidx.appcompat.widget.AppCompatButton
        android:id="@+id/btnFrench"
        style="@style/LanguageButtonStyle"
        android:layout_marginTop="20dp"
        android:text="@string/lang_french" />

    <androidx.appcompat.widget.AppCompatButton
        android:id="@+id/btnArabic"
        style="@style/LanguageButtonStyle"
        android:layout_marginTop="20dp"
        android:text="@string/lang_arabic" />

</LinearLayout>