<?xml version="1.0" encoding="utf-8"?>
<!--
    Language Selection Screen
    Updated to match the grid design with a header and better styling.
-->
<RelativeLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF">

    <!-- Header -->
    <RelativeLayout
        android:id="@+id/header"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:paddingHorizontal="16dp">

        <ImageView
            android:id="@+id/btnBack"
            android:layout_width="30dp"
            android:layout_height="30dp"
            android:layout_centerVertical="true"
            android:src="@android:drawable/ic_menu_revert"
            app:tint="#3498DB"
            android:contentDescription="@null"
            android:clickable="true"
            android:focusable="true" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerInParent="true"
            android:text="LANGUE"
            android:textColor="#3498DB"
            android:textSize="18sp"
            android:textStyle="bold" />
    </RelativeLayout>

    <!-- Language Grid -->
    <LinearLayout
        android:id="@+id/languageGrid"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@id/header"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Row 1 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btnTurkish"
                android:layout_width="0dp"
                android:layout_height="90dp"
                android:layout_weight="1"
                android:layout_margin="8dp"
                android:background="@drawable/button_shape_global"
                android:text="@string/lang_turkish"
                android:textAllCaps="false"
                android:textColor="#3498DB"
                android:textSize="16sp"
                android:textStyle="bold" />

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btnEnglish"
                android:layout_width="0dp"
                android:layout_height="90dp"
                android:layout_weight="1"
                android:layout_margin="8dp"
                android:background="@drawable/button_shape_global"
                android:text="@string/lang_english"
                android:textAllCaps="false"
                android:textColor="#3498DB"
                android:textSize="16sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- Row 2 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btnFrench"
                android:layout_width="0dp"
                android:layout_height="90dp"
                android:layout_weight="1"
                android:layout_margin="8dp"
                android:background="@drawable/button_shape_global"
                android:text="@string/lang_french"
                android:textAllCaps="false"
                android:textColor="#3498DB"
                android:textSize="16sp"
                android:textStyle="bold" />

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btnArabic"
                android:layout_width="0dp"
                android:layout_height="90dp"
                android:layout_weight="1"
                android:layout_margin="8dp"
                android:background="@drawable/button_shape_global"
                android:text="@string/lang_arabic"
                android:textAllCaps="false"
                android:textColor="#3498DB"
                android:textSize="16sp"
                android:textStyle="bold" />
        </LinearLayout>

    </LinearLayout>

    <!-- Valider Button -->
    <androidx.appcompat.widget.AppCompatButton
        android:id="@+id/btnValiderLanguage"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:layout_alignParentBottom="true"
        android:layout_margin="24dp"
        android:background="@drawable/bg_blue_btn"
        android:text="@string/btn_validate"
        android:textColor="#FFFFFF"
        android:textStyle="bold"
        android:visibility="gone" />

</RelativeLayout>