<?xml version="1.0" encoding="utf-8"?>
<!--
    Ajouter Fournisseur Screen
    Similar to Ajouter Client but with the Fournisseur title.
-->
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF">

    <!-- Header -->
    <RelativeLayout
        android:id="@+id/header"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="16dp">

        <ImageView
            android:id="@+id/btnBack"
            android:layout_width="30dp"
            android:layout_height="30dp"
            android:layout_centerVertical="true"
            android:src="@android:drawable/ic_menu_revert"
            app:tint="#3498DB" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerInParent="true"
            android:text="@string/title_ajouter_fournisseur"
            android:textColor="#3498DB"
            android:textSize="18sp"
            android:textStyle="bold" />
    </RelativeLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@id/header"
        android:layout_above="@id/btnConfirmer"
        android:padding="24dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Name Input -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/label_nom"
                android:textColor="#3498DB"
                android:textSize="12sp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/etNom"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="@string/hint_nom"
                android:background="@null"
                android:paddingTop="8dp"
                android:paddingBottom="12dp"
                android:textSize="16sp"
                android:inputType="textPersonName" />

            <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#EEEEEE" />

            <!-- Phone Input -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:text="@string/label_phone"
                android:textColor="#3498DB"
                android:textSize="12sp"
                android:textStyle="bold" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="40dp"
                    android:background="@drawable/bg_light_blue_btn"
                    android:paddingStart="8dp"
                    android:paddingEnd="8dp"
                    android:gravity="center">
                    <ImageView android:layout_width="20dp" android:layout_height="20dp" android:src="@drawable/ic_launcher_foreground" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="+213" android:layout_marginStart="4dp" />
                </LinearLayout>

                <EditText
                    android:id="@+id/etPhone"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="12dp"
                    android:hint="@string/hint_phone"
                    android:background="@null"
                    android:inputType="phone"
                    android:paddingTop="8dp"
                    android:paddingBottom="12dp"
                    android:textSize="16sp" />
            </LinearLayout>
            <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#EEEEEE" />

            <!-- Address Input -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:text="@string/label_adresse"
                android:textColor="#3498DB"
                android:textSize="12sp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/etAddress"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="@string/hint_adresse"
                android:background="@null"
                android:paddingTop="8dp"
                android:paddingBottom="12dp"
                android:textSize="16sp" />
            <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#EEEEEE" />

            <!-- Tags Section -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                app:cardCornerRadius="8dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="#FFFFFF"
                app:contentPadding="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/label_tags"
                            android:textColor="#3498DB"
                            android:textSize="18sp"
                            android:textStyle="bold" />

                        <androidx.appcompat.widget.AppCompatButton
                            android:id="@+id/btnGoToTags"
                            android:layout_width="wrap_content"
                            android:layout_height="35dp"
                            android:layout_alignParentEnd="true"
                            android:background="@drawable/bg_light_blue_btn"
                            android:text="@string/btn_ajouter_tags"
                            android:textAllCaps="false"
                            android:textColor="#3498DB"
                            android:textSize="12sp" />
                    </RelativeLayout>

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:text="@string/tags_desc"
                        android:textColor="#BDC3C7"
                        android:textSize="12sp" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

        </LinearLayout>
    </ScrollView>

    <androidx.appcompat.widget.AppCompatButton
        android:id="@+id/btnConfirmer"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:layout_alignParentBottom="true"
        android:layout_margin="24dp"
        android:background="@drawable/button_shape_global"
        android:backgroundTint="#3498DB"
        android:text="@string/btn_confirmer"
        android:textColor="#FFFFFF"
        android:textStyle="bold" />

</RelativeLayout>