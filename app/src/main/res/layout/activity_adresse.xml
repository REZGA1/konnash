<?xml version="1.0" encoding="utf-8"?>
<!--
    Adresse Screen
    Allows user to input address, city, and country.
-->
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/main_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF">

    <!-- Header -->
    <RelativeLayout
        android:id="@+id/header"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="16dp">

        <ImageView
            android:id="@+id/btnClose"
            android:layout_width="30dp"
            android:layout_height="30dp"
            android:layout_centerVertical="true"
            android:src="@android:drawable/ic_menu_close_clear_cancel"
            app:tint="#3498DB" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerInParent="true"
            android:text="@string/title_adresse"
            android:textColor="#3498DB"
            android:textSize="18sp"
            android:textStyle="bold" />
    </RelativeLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@id/header"
        android:orientation="vertical"
        android:padding="24dp">

        <!-- Adresse Field -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/label_adresse"
            android:textColor="#3498DB"
            android:textSize="12sp"
            android:textStyle="bold" />
        <EditText
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/hint_adresse"
            android:background="@null"
            android:paddingTop="8dp"
            android:paddingBottom="12dp"
            android:textSize="16sp" />
        <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#EEEEEE" />

        <!-- Ville Field -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="@string/label_ville"
            android:textColor="#3498DB"
            android:textSize="12sp"
            android:textStyle="bold" />
        <EditText
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/hint_ville"
            android:background="@null"
            android:paddingTop="8dp"
            android:paddingBottom="12dp"
            android:textSize="16sp" />
        <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#EEEEEE" />

        <!-- Pays Field -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="@string/label_pays"
            android:textColor="#3498DB"
            android:textSize="12sp"
            android:textStyle="bold" />
        <EditText
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/hint_pays"
            android:background="@null"
            android:paddingTop="8dp"
            android:paddingBottom="12dp"
            android:textSize="16sp" />
        <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#EEEEEE" />

    </LinearLayout>

    <androidx.appcompat.widget.AppCompatButton
        android:id="@+id/btnValider"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:layout_alignParentBottom="true"
        android:layout_margin="24dp"
        android:background="@drawable/button_shape_global"
        android:backgroundTint="#3498DB"
        android:text="@string/btn_validate"
        android:textColor="#FFFFFF"
        android:textStyle="bold" />

</RelativeLayout>