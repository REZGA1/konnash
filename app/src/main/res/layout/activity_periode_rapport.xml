<?xml version="1.0" encoding="utf-8"?>
<!--
    Période Rapport Screen
    Updated: Uses a RadioGroup for single selection of predefined periods.
    Selected text darkens automatically via color selector.
-->
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF">

    <!-- Header -->
    <RelativeLayout
        android:id="@+id/header"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="16dp">

        <ImageView
            android:id="@+id/btnClose"
            android:layout_width="30dp"
            android:layout_height="30dp"
            android:layout_centerVertical="true"
            android:src="@android:drawable/ic_menu_close_clear_cancel"
            app:tint="#3498DB"
            android:contentDescription="@null" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerInParent="true"
            android:text="@string/title_periode_rapport"
            android:textColor="#3498DB"
            android:textSize="18sp"
            android:textStyle="bold" />
    </RelativeLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@id/header"
        android:layout_above="@id/btnApply"
        android:padding="16dp"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Date Personnalisée Section -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">
                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@android:drawable/ic_menu_my_calendar"
                    app:tint="#3498DB"
                    android:contentDescription="@null" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="12dp"
                    android:text="@string/label_custom_date"
                    android:textColor="#333333"
                    android:textStyle="bold" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:orientation="horizontal">
                <TextView
                    android:id="@+id/tvStartDate"
                    android:layout_width="0dp"
                    android:layout_height="45dp"
                    android:layout_weight="1"
                    android:layout_marginEnd="8dp"
                    android:background="@drawable/bg_light_blue_btn"
                    android:gravity="center"
                    android:text="@string/label_start_date"
                    android:textColor="#BDC3C7"
                    android:clickable="true"
                    android:focusable="true" />
                <TextView
                    android:id="@+id/tvEndDate"
                    android:layout_width="0dp"
                    android:layout_height="45dp"
                    android:layout_weight="1"
                    android:layout_marginStart="8dp"
                    android:background="@drawable/bg_light_blue_btn"
                    android:gravity="center"
                    android:text="@string/label_end_date"
                    android:textColor="#BDC3C7"
                    android:clickable="true"
                    android:focusable="true" />
            </LinearLayout>

            <View android:layout_width="match_parent" android:layout_height="1dp" android:layout_marginTop="24dp" android:background="#EEEEEE" />

            <!-- Single Selection Period List -->
            <RadioGroup
                android:id="@+id/rgPeriods"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp">

                <RadioButton
                    android:id="@+id/rbAllDates"
                    android:layout_width="match_parent"
                    android:layout_height="60dp"
                    android:text="@string/label_all_dates"
                    android:textColor="@color/selector_selection_text"
                    android:buttonTint="#3498DB"
                    android:checked="true"
                    android:textSize="16sp" />

                <RadioButton
                    android:id="@+id/rbToday"
                    android:layout_width="match_parent"
                    android:layout_height="60dp"
                    android:text="@string/label_today"
                    android:textColor="@color/selector_selection_text"
                    android:buttonTint="#3498DB"
                    android:textSize="16sp" />

                <RadioButton
                    android:id="@+id/rbYesterday"
                    android:layout_width="match_parent"
                    android:layout_height="60dp"
                    android:text="@string/label_yesterday"
                    android:textColor="@color/selector_selection_text"
                    android:buttonTint="#3498DB"
                    android:textSize="16sp" />

                <RadioButton
                    android:id="@+id/rbThisWeek"
                    android:layout_width="match_parent"
                    android:layout_height="60dp"
                    android:text="@string/label_this_week"
                    android:textColor="@color/selector_selection_text"
                    android:buttonTint="#3498DB"
                    android:textSize="16sp" />

                <RadioButton
                    android:id="@+id/rbLastWeek"
                    android:layout_width="match_parent"
                    android:layout_height="60dp"
                    android:text="@string/label_last_week"
                    android:textColor="@color/selector_selection_text"
                    android:buttonTint="#3498DB"
                    android:textSize="16sp" />

                <RadioButton
                    android:id="@+id/rbCurrentMonth"
                    android:layout_width="match_parent"
                    android:layout_height="60dp"
                    android:text="@string/label_current_month"
                    android:textColor="@color/selector_selection_text"
                    android:buttonTint="#3498DB"
                    android:textSize="16sp" />

            </RadioGroup>

        </LinearLayout>
    </ScrollView>

    <androidx.appcompat.widget.AppCompatButton
        android:id="@+id/btnApply"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:layout_alignParentBottom="true"
        android:layout_margin="16dp"
        android:background="@drawable/button_shape_global"
        android:backgroundTint="#3498DB"
        android:text="@string/btn_apply"
        android:textColor="#FFFFFF"
        android:textStyle="bold" />

</RelativeLayout>