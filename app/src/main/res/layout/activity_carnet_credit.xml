<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/main_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF">

    <!-- Header Section -->
    <LinearLayout
        android:id="@+id/header"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="16dp">

        <ImageView
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/book_icon" />

        <TextView
            android:id="@+id/tvShopName"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="8dp"
            android:text="@string/shop_name"
            android:textColor="#3498DB"
            android:textSize="16sp"
            android:textStyle="bold" />

        <ImageView
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_marginEnd="8dp"
            android:background="@drawable/bg_light_blue_btn"
            android:padding="8dp"
            android:src="@android:drawable/ic_menu_slideshow"
            app:tint="#3498DB" />

        <ImageView
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_marginEnd="8dp"
            android:background="@drawable/bg_light_blue_btn"
            android:padding="8dp"
            android:src="@android:drawable/ic_menu_view"
            app:tint="#3498DB" />

        <ImageView
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="@drawable/bg_light_blue_btn"
            android:padding="8dp"
            android:src="@drawable/yt_icon" />
    </LinearLayout>

    <!-- Tab Bar -->
    <LinearLayout
        android:id="@+id/tab_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@id/header"
        android:paddingHorizontal="16dp"
        android:orientation="horizontal">

        <LinearLayout
            android:id="@+id/btnTabClients"
            android:layout_width="0dp"
            android:layout_height="45dp"
            android:layout_weight="1"
            android:gravity="center"
            android:background="@drawable/bg_light_blue_btn"
            android:orientation="horizontal">
            <ImageView android:layout_width="18dp" android:layout_height="18dp" android:src="@drawable/profile_icon_page" app:tint="#3498DB"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:text="CLIENTS"
                android:textColor="#3498DB"
                android:textStyle="bold" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/btnTabFournisseurs"
            android:layout_width="0dp"
            android:layout_height="45dp"
            android:layout_weight="1"
            android:gravity="center"
            android:layout_marginStart="8dp">
            <ImageView android:layout_width="18dp" android:layout_height="18dp" android:src="@android:drawable/ic_dialog_map" app:tint="#BDC3C7"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:text="FOURNISSEURS"
                android:textColor="#BDC3C7" />
        </LinearLayout>
    </LinearLayout>

    <!-- Summary Box -->
    <androidx.cardview.widget.CardView
        android:id="@+id/summary_card"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@id/tab_container"
        android:layout_margin="16dp"
        app:cardCornerRadius="12dp"
        app:cardElevation="2dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="16dp"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="J'ai pris" android:textSize="12sp" android:textColor="#7F8C8D" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="0.0 DA" android:textColor="#2ECC71" android:textSize="18sp" android:textStyle="bold" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="8dp" android:text="J'ai donné" android:textSize="12sp" android:textColor="#7F8C8D" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="0.0 DA" android:textColor="#E74C3C" android:textSize="18sp" android:textStyle="bold" />
            </LinearLayout>

            <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content" android:orientation="horizontal">
                <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content" android:orientation="vertical" android:gravity="center" android:layout_marginEnd="16dp">
                    <ImageView android:layout_width="45dp" android:layout_height="45dp" android:background="@drawable/bg_light_blue_btn" android:padding="12dp" android:src="@android:drawable/ic_popup_reminder" app:tint="#3498DB" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Recouvrement" android:textSize="10sp" android:textColor="#7F8C8D" />
                </LinearLayout>
                <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content" android:orientation="vertical" android:gravity="center">
                    <ImageView android:layout_width="45dp" android:layout_height="45dp" android:background="@drawable/bg_light_blue_btn" android:padding="12dp" android:src="@android:drawable/ic_menu_sort_by_size" app:tint="#3498DB" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Rapports" android:textSize="10sp" android:textColor="#7F8C8D" />
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <!-- Search Section -->
    <LinearLayout
        android:id="@+id/search_section"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@id/summary_card"
        android:paddingHorizontal="16dp"
        android:orientation="vertical">

        <TextView android:id="@+id/tvClientsCount" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Clients (0)" android:textColor="#3498DB" android:textStyle="bold" />

        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginTop="8dp">
            <EditText
                android:layout_width="0dp"
                android:layout_height="45dp"
                android:layout_weight="1"
                android:background="@drawable/bg_light_blue_btn"
                android:drawableStart="@android:drawable/ic_menu_search"
                android:drawablePadding="8dp"
                android:hint="Recherche"
                android:paddingStart="12dp"
                android:textSize="14sp"
                android:inputType="text" />
            <ImageView android:id="@+id/btnFilter" android:layout_width="45dp" android:layout_height="45dp" android:layout_marginStart="8dp" android:background="@drawable/bg_light_blue_btn" android:padding="12dp" android:src="@android:drawable/ic_menu_preferences" app:tint="#3498DB" />
            <ImageView android:layout_width="45dp" android:layout_height="45dp" android:layout_marginStart="8dp" android:background="@drawable/bg_light_blue_btn" android:padding="12dp" android:src="@android:drawable/ic_menu_save" app:tint="#3498DB" />
        </LinearLayout>
    </LinearLayout>

    <!-- Content Area (List or Empty State) -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@id/search_section"
        android:layout_above="@id/bottom_navigation">

        <!-- Clients List -->
        <ScrollView android:layout_width="match_parent" android:layout_height="match_parent">
            <LinearLayout android:id="@+id/clientsContainer" android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" />
        </ScrollView>

        <!-- Empty State -->
        <LinearLayout
            android:id="@+id/emptyStateContainer"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="40dp"
            android:visibility="visible">
            <ImageView
                android:layout_width="180dp"
                android:layout_height="180dp"
                android:src="@drawable/carnet_credit_illustration" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:gravity="center"
                android:text="Aucun client pour le moment. Ajoutez des clients pour commencer à gérer les crédits"
                android:textColor="#95A5A6"
                android:textSize="15sp"
                android:lineSpacingExtra="4dp" />
        </LinearLayout>
    </FrameLayout>

    <!-- Floating Action Button -->
    <LinearLayout
        android:id="@+id/btnFABAddClient"
        android:layout_width="wrap_content"
        android:layout_height="55dp"
        android:layout_alignParentEnd="true"
        android:layout_above="@id/bottom_navigation"
        android:layout_margin="16dp"
        android:paddingHorizontal="24dp"
        android:background="@drawable/bg_blue_btn"
        android:gravity="center"
        android:orientation="horizontal"
        android:elevation="6dp">
        <ImageView android:layout_width="24dp" android:layout_height="24dp" android:src="@drawable/profile_icon_page" app:tint="#FFFFFF" />
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginStart="10dp" android:text="Ajouter client" android:textColor="#FFFFFF" android:textStyle="bold" />
    </LinearLayout>

    <!-- Bottom Navigation -->
    <LinearLayout
        android:id="@+id/bottom_navigation"
        android:layout_width="match_parent"
        android:layout_height="70dp"
        android:layout_alignParentBottom="true"
        android:background="#FFFFFF"
        android:paddingTop="8dp">
        <LinearLayout android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:orientation="vertical" android:gravity="center">
            <ImageView android:layout_width="24dp" android:layout_height="24dp" android:src="@drawable/book_icon" app:tint="#3498DB" />
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Carnet Crédit" android:textColor="#3498DB" android:textSize="11sp" />
        </LinearLayout>
        <LinearLayout android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:orientation="vertical" android:gravity="center">
            <ImageView android:layout_width="24dp" android:layout_height="24dp" android:src="@drawable/carnet_caisse_icon_page" app:tint="#7F8C8D" />
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Carnet Caisse" android:textColor="#7F8C8D" android:textSize="11sp" />
        </LinearLayout>
        <LinearLayout android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:orientation="vertical" android:gravity="center">
            <ImageView android:layout_width="24dp" android:layout_height="24dp" android:src="@drawable/profile_icon_page" app:tint="#7F8C8D" />
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Profil" android:textColor="#7F8C8D" android:textSize="11sp" />
        </LinearLayout>
    </LinearLayout>

    <View android:layout_width="match_parent" android:layout_height="1dp" android:layout_above="@id/bottom_navigation" android:background="#EEEEEE" />

</RelativeLayout>