<?xml version="1.0" encoding="utf-8"?>
<!--
    Rapports Screen
    Displays a summary of transactions for a selected period.
-->
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF">

    <!-- Header -->
    <RelativeLayout
        android:id="@+id/header"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="16dp">

        <ImageView
            android:id="@+id/btnBack"
            android:layout_width="30dp"
            android:layout_height="30dp"
            android:layout_centerVertical="true"
            android:src="@android:drawable/ic_menu_revert"
            app:tint="#3498DB"
            android:contentDescription="@null" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerInParent="true"
            android:text="@string/title_rapports"
            android:textColor="#3498DB"
            android:textSize="18sp"
            android:textStyle="bold" />
    </RelativeLayout>

    <!-- Period Selector Section -->
    <RelativeLayout
        android:id="@+id/period_section"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@id/header"
        android:padding="16dp">

        <ImageView
            android:id="@+id/ivCalendar"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_centerVertical="true"
            android:src="@android:drawable/ic_menu_today"
            app:tint="#3498DB"
            android:contentDescription="@null" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerVertical="true"
            android:layout_marginStart="8dp"
            android:layout_toEndOf="@id/ivCalendar"
            android:text="@string/label_all_dates"
            android:textColor="#333333"
            android:textSize="14sp" />

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btnModifyPeriod"
            android:layout_width="wrap_content"
            android:layout_height="35dp"
            android:layout_alignParentEnd="true"
            android:background="@drawable/bg_light_blue_btn"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:text="@string/btn_modify_period"
            android:textAllCaps="false"
            android:textColor="#3498DB"
            android:textSize="12sp" />
    </RelativeLayout>

    <!-- Financial Summary -->
    <LinearLayout
        android:id="@+id/financial_summary"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@id/period_section"
        android:orientation="vertical"
        android:padding="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="vertical">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/label_i_took" android:textColor="#7F8C8D" android:textSize="12sp" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="0.0 DA" android:textColor="#27AE60" android:textSize="18sp" android:textStyle="bold" tools:ignore="HardcodedText" />
            </LinearLayout>

            <View android:layout_width="1dp" android:layout_height="match_parent" android:background="#EEEEEE" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="vertical">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/label_i_gave" android:textColor="#7F8C8D" android:textSize="12sp" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="6.0 DA" android:textColor="#E74C3C" android:textSize="18sp" android:textStyle="bold" tools:ignore="HardcodedText" />
            </LinearLayout>
        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:layout_marginTop="16dp"
            android:text="@string/label_net_balance"
            android:textColor="#BDC3C7"
            android:textSize="12sp" />
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:text="6.0 DA"
            android:textColor="#E74C3C"
            android:textSize="14sp"
            android:textStyle="bold" tools:ignore="HardcodedText" />
    </LinearLayout>

    <View
        android:id="@+id/divider"
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_below="@id/financial_summary"
        android:background="#EEEEEE" />

    <!-- Operations List Area -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_above="@id/btnDownload"
        android:layout_below="@id/divider"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/label_operations_count"
            android:textColor="#3498DB"
            android:textStyle="bold" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <EditText
                android:layout_width="0dp"
                android:layout_height="45dp"
                android:layout_weight="1"
                android:background="@drawable/bg_light_blue_btn"
                android:hint="@string/hint_search_transactions"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:textSize="14sp"
                android:inputType="text"
                android:autofillHints="name" />

            <ImageView
                android:id="@+id/btnSort"
                android:layout_width="45dp"
                android:layout_height="45dp"
                android:layout_marginStart="8dp"
                android:background="@drawable/bg_light_blue_btn"
                android:padding="12dp"
                android:src="@android:drawable/ic_menu_preferences"
                app:tint="#3498DB"
                android:contentDescription="@null"
                android:clickable="true"
                android:focusable="true" />
        </LinearLayout>

        <!-- Transaction Item Placeholder -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:gravity="center_vertical">
            <ImageView
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="@drawable/bg_light_blue_btn"
                android:padding="10dp"
                android:src="@android:drawable/arrow_up_float"
                app:tint="#333333"
                android:contentDescription="@null" />
            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:layout_weight="1"
                android:text="Mohamed Bbay"
                android:textColor="#333333"
                android:textStyle="bold" />
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="end"
                android:orientation="vertical">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="6.0 DA" android:textColor="#E74C3C" android:textStyle="bold" tools:ignore="HardcodedText" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="J'ai donné" android:textColor="#BDC3C7" android:textSize="10sp" />
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>

    <!-- Download Button -->
    <androidx.appcompat.widget.AppCompatButton
        android:id="@+id/btnDownload"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:layout_alignParentBottom="true"
        android:layout_margin="16dp"
        android:background="@drawable/button_shape_global"
        android:backgroundTint="#3498DB"
        android:text="@string/btn_download"
        android:textColor="#FFFFFF"
        android:textStyle="bold" />

</RelativeLayout>