<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Base.Theme.Konnash" parent="Theme.Material3.Light.NoActionBar">
        <!-- Customize your light theme here. -->
        <item name="android:windowBackground">@android:color/white</item>
        <item name="android:statusBarColor">@android:color/white</item>
        <item name="android:windowLightStatusBar">true</item>
    </style>

    <!--
        Custom Style for Language Selection Buttons
        - Changed layout_width to 280dp (fixed width) so they don't match the parent width.
        - Height is set to 80dp for a comfortable tap target.
        - Background uses our custom rounded shape.
    -->
    <style name="LanguageButtonStyle" parent="Widget.AppCompat.Button">
        <item name="android:layout_width">280dp</item>
        <item name="android:layout_height">80dp</item>
        <item name="android:background">@drawable/button_shape_global</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:textColor">#4285F4</item>
        <item name="android:textSize">18sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:stateListAnimator">@null</item>
        <item name="android:elevation">0dp</item>
    </style>

    <style name="Theme.Konnash" parent="Base.Theme.Konnash" />
</resources>